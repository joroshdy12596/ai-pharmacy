# Copy this file to .env on the pharmacy PC and fill in real values.
# .env is already in .gitignore - never commit the real one.

# Django
SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
# Space-separated hosts Django will accept requests for. Must include the
# hostname you route through Cloudflare Tunnel, e.g.:
# DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 pharmacy.yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1]
# Comma-separated, full scheme+host, e.g.:
# CSRF_TRUSTED_ORIGINS=https://pharmacy.yourdomain.com
CSRF_TRUSTED_ORIGINS=

# Superuser bootstrapped on first container start - change these from the
# admin/admin defaults before exposing the app publicly.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_EMAIL=admin@example.com

# Reports basic-auth (see Elesraa/middleware.py)
REPORTS_BASIC_AUTH_USER=
REPORTS_BASIC_AUTH_PASS=

# Cloudflare Tunnel token (Zero Trust dashboard -> Networks -> Tunnels ->
# Create a tunnel -> Docker -> copy the token after "run")
CLOUDFLARE_TUNNEL_TOKEN=

# Shared secret for the GitHub webhook that triggers an instant db.sqlite3
# pull on every push (see pharmacy/views_webhook.py). Generate any long
# random string and use the same value in the GitHub repo's webhook config.
GITHUB_WEBHOOK_SECRET=

# Telegram bot for staff notifications (see pharmacy/telegram_utils.py)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public base URL (no trailing slash), used to build links in messages sent
# from contexts with no HTTP request (e.g. remind_pending_prescriptions).
# Update whenever the Cloudflare Tunnel URL changes.
PUBLIC_SITE_URL=

# International format, no leading 0/+ (e.g. 201022815980 for Egypt), for
# the WhatsApp click-to-chat button on guest-facing pages.
WHATSAPP_NUMBER=
